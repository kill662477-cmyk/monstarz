# MONSTARZNEW 환경변수 예시 (Phase 5 Supabase)
# 이 파일은 Git 에 커밋되는 "템플릿" 입니다. 실제 키를 절대 여기에 넣지 마세요.
# 실제 값은 .env.local 에 넣고, .env.local 은 절대 Git 에 커밋하지 마세요.
# Vercel 에서는 Project Settings > Environment Variables 에 동일하게 넣습니다.

# --- 브라우저에 노출되어도 되는 공개 값 (RLS 로 보호됨) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 새 Supabase 콘솔에서는 anon 대신 publishable 키를 줄 수 있습니다. 둘 중 하나만 채우면 됩니다.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- 서버 전용 (절대 브라우저에 노출 금지, NEXT_PUBLIC_ 접두사 쓰지 말 것) ---
# service_role 또는 secret 키. 서버리스 함수(api/)에서만 사용합니다.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# --- 관리자 접근 보호용 (서버 전용) ---
# /api/admin/auth 에서 이 값과 입력한 관리자 코드를 비교합니다.
# 절대 프론트 코드에 하드코딩하거나 NEXT_PUBLIC_ 으로 노출하지 마세요.
ADMIN_SECRET=

# 주의:
# - NEXT_PUBLIC_* 값은 /api/supabase-config 를 통해 브라우저로 전달됩니다 (공개 읽기용).
# - SUPABASE_SERVICE_ROLE_KEY / SUPABASE_SECRET_KEY / ADMIN_SECRET 은 서버리스 함수에서만 읽습니다.
# - 환경변수가 하나도 없어도 사이트는 기존 Firebase/JSON fallback 으로 정상 동작합니다.
