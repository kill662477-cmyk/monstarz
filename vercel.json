{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": ".",
  "functions": {
    "api/soop-token.js": {
      "maxDuration": 10
    },
    "api/soop-refresh.js": {
      "maxDuration": 10
    },
    "api/supabase-config.js": {
      "maxDuration": 10
    },
    "api/schedule-today.js": {
      "maxDuration": 10
    },
    "api/admin/index.js": {
      "maxDuration": 10
    },
    "api/public-overrides.js": {
      "maxDuration": 10
    },
    "api/tier-records.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/admin/(.*)", "destination": "/api/admin?path=$1" }
  ]
}
